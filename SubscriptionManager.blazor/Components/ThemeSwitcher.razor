@using SubscriptionManager.blazor.Services
@inject IThemeService Theme
@implements IDisposable

<div class="theme-switcher"
     role="radiogroup"
     aria-label="테마 선택"
     @ref="_root"
     @onmousedown="OnMouseDown"
     @onmousedown:preventDefault="true">
    <div class="theme-switcher-thumb" style="transform: translateX(@(ThumbOffsetPx)px);"></div>

    @for (var i = 0; i < _options.Length; i++)
    {
        var idx = i;
        var opt = _options[idx];
        var active = Theme.Mode == opt.Mode;
        <button type="button"
                class="theme-opt @(active ? "active" : "")"
                role="radio"
                aria-checked="@(active ? "true" : "false")"
                aria-label="@opt.Label"
                title="@opt.Label"
                @onclick="@(() => Set(opt.Mode))">
            <MudIcon Icon="@opt.Icon" Size="Size.Small" />
        </button>
    }
</div>

@code {
    private ElementReference _root;

    private record Option(ThemeMode Mode, string Label, string Icon);

    private readonly Option[] _options =
    [
        new(ThemeMode.Light,  "라이트", Icons.Material.Filled.LightMode),
        new(ThemeMode.Dark,   "다크",   Icons.Material.Filled.DarkMode),
        new(ThemeMode.System, "시스템", Icons.Material.Filled.BrightnessAuto),
    ];

    private const int OptionWidth = 36; // CSS의 .theme-opt width 와 일치

    private int CurrentIndex => Array.FindIndex(_options, o => o.Mode == Theme.Mode);
    private int ThumbOffsetPx => CurrentIndex >= 0 ? CurrentIndex * OptionWidth : 0;

    protected override void OnInitialized()
    {
        Theme.OnChange += OnChange;
    }

    private async Task Set(ThemeMode mode)
    {
        await Theme.SetModeAsync(mode);
    }

    // 마우스 다운 → 시작 위치 기록 + 드래그 모드 진입. 끌어서 옵션 사이를 이동.
    private double _dragStartX;
    private int _dragStartIndex;
    private bool _dragging;

    private async Task OnMouseDown(MouseEventArgs e)
    {
        _dragging = true;
        _dragStartX = e.ClientX;
        _dragStartIndex = Math.Max(0, CurrentIndex);

        // 시작 시 클릭한 옵션으로 즉시 이동 (drag 없이 click 한 경우 자연스럽도록 click 핸들러가 처리)
        await Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnPointerMoveJs(double clientX)
    {
        if (!_dragging) return;
        var delta = clientX - _dragStartX;
        var steps = (int)Math.Round(delta / OptionWidth);
        var target = Math.Clamp(_dragStartIndex + steps, 0, _options.Length - 1);
        if (target != CurrentIndex)
        {
            await Set(_options[target].Mode);
        }
    }

    [JSInvokable]
    public void OnPointerUpJs() => _dragging = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _selfRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("subTrackThemeSwitcher.attach", _root, _selfRef);
            }
            catch { /* JS 로드 안 됨 — 드래그 없이 클릭만 동작 */ }
        }
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
    private DotNetObjectReference<ThemeSwitcher>? _selfRef;

    private void OnChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Theme.OnChange -= OnChange;
        if (_selfRef != null)
        {
            try { _ = JS.InvokeVoidAsync("subTrackThemeSwitcher.detach", _root); } catch { }
            _selfRef.Dispose();
        }
    }
}
