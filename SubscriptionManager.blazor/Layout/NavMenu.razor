        <div class="nav-item px-3">
            <NavLink class="nav-link" href="subscriptions">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> 구독 관리
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="spending-analysis">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> 지출 분석
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
