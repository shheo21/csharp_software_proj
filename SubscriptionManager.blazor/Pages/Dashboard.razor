@page "/"
@inject ISubscriptionApiService ApiService
@inject NavigationManager Nav

<PageTitle>대시보드 — SubTrack</PageTitle>

<div class="fade-in-up">
    <!-- Header -->
    <div class="d-flex align-center justify-space-between mb-6">
        <div>
            <div class="page-title">대시보드</div>
            <div class="page-subtitle">@DateTime.Now.ToString("yyyy년 M월 d일 dddd")</div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center pa-16">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else if (_summary != null)
    {
        <!-- KPI Summary Cards -->
        <MudGrid Spacing="3" Class="mb-5">
            <MudItem xs="12" sm="6" md="3" Class="fade-in-up fade-in-up-1">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px; position:relative; overflow:hidden;">
                    <div style="position:absolute; top:-20px; right:-20px; width:100px; height:100px;
                                border-radius:50%; background: radial-gradient(circle, rgba(99,102,241,0.1), transparent);"></div>
                    <div class="stat-label mb-2">이번 달 예상 지출</div>
                    <div class="stat-value" style="color: var(--gold-400);">
                        ₩@_summary.TotalMonthlyKRW.ToString("N0")
                    </div>
                    <MudText Typo="Typo.caption" Style="color: var(--text-secondary); margin-top:4px;">
                        월 환산 기준
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" md="3" Class="fade-in-up fade-in-up-2">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px;">
                    <div class="stat-label mb-2">연간 예상 지출</div>
                    <div class="stat-value">₩@_summary.TotalYearlyKRW.ToString("N0")</div>
                    <MudText Typo="Typo.caption" Style="color: var(--accent-blue); margin-top:4px;">
                        월 평균 ₩@(_summary.TotalMonthlyKRW.ToString("N0"))
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" md="3" Class="fade-in-up fade-in-up-3">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px;">
                    <div class="stat-label mb-2">활성 구독</div>
                    <div class="stat-value" style="color: var(--accent-green);">@_summary.ActiveCount</div>
                    <MudText Typo="Typo.caption" Style="color: var(--text-secondary); margin-top:4px;">
                        서비스
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" md="3" Class="fade-in-up fade-in-up-4">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px;">
                    <div class="stat-label mb-2">7일 내 결제 예정</div>
                    <div class="stat-value" style="color: var(--accent-red);">
                        @_summary.UpcomingBilling.Count(u => u.DaysUntilBilling <= 7)
                    </div>
                    <MudText Typo="Typo.caption" Style="color: var(--text-secondary); margin-top:4px;">
                        건
                    </MudText>
                </div>
            </MudItem>
        </MudGrid>

        <!-- Body: Upcoming + Category Chart -->
        <MudGrid Spacing="3">
            <!-- Upcoming Billing (Priority Queue sorted) -->
            <MudItem xs="12" md="7" Class="fade-in-up fade-in-up-2">
                <div class="glass-card pa-5">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Style="color: var(--gold-400);" Class="mr-2" />
                        <MudText Typo="Typo.h6" Style="font-weight:700; color: var(--text-primary);">결제 예정</MudText>
                        <MudSpacer />
                        <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                 Style="background:rgba(99,102,241,0.1); color:var(--gold-400); font-size:0.72rem;">
                            D-Day 순
                        </MudChip>
                    </div>

                    @foreach (var sub in _summary.UpcomingBilling.Take(8))
                    {
                        <div class="d-flex align-center py-3" style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                            <div class="sub-icon mr-3">@(sub.IconEmoji ?? "📦")</div>
                            <div class="flex-grow-1">
                                <div style="font-weight:600; color: var(--text-primary); font-size:0.92rem;">
                                    @sub.Name
                                </div>
                                <div style="font-size:0.75rem; color: var(--text-secondary);">
                                    @sub.Category · @sub.BillingCycleLabel
                                </div>
                            </div>
                            <div class="text-right mr-3">
                                <div style="font-weight:700; color: var(--text-primary); font-size:0.92rem;">
                                    ₩@sub.AmountInKRW.ToString("N0")
                                </div>
                                <div style="font-size:0.72rem; color: var(--text-secondary);">
                                    @(sub.Currency != "KRW" ? $"{sub.Currency} {sub.Amount:N2}" : "")
                                </div>
                            </div>
                            <div class="dday-badge" style="background: @(sub.DaysBadgeColor)22; color: @sub.DaysBadgeColor; border: 1px solid @(sub.DaysBadgeColor)44; min-width:52px; justify-content:center;">
                                @sub.DaysLabel
                            </div>
                        </div>
                    }
                </div>
            </MudItem>

            <!-- Category Breakdown -->
            <MudItem xs="12" md="5" Class="fade-in-up fade-in-up-3">
                <div class="glass-card pa-5" style="height:100%; cursor:pointer;"
                     @onclick='() => Nav.NavigateTo("/spending-analysis")'
                     title="클릭하여 지출 분석 페이지로 이동">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.PieChart" Style="color: var(--gold-400);" Class="mr-2" />
                        <MudText Typo="Typo.h6" Style="font-weight:700; color: var(--text-primary);">카테고리별 지출</MudText>
                        <MudSpacer />
                        <MudText Typo="Typo.caption"
                                 Style="color:var(--gold-500);font-size:0.72rem;display:flex;align-items:center;gap:4px;">
                            상세 분석 →
                        </MudText>
                    </div>

                    <!-- SVG Donut Chart -->
                    @{
                        var total = _summary.CategoryBreakdown.Sum(c => c.MonthlyAmountKRW);
                        var colors = new[] { "#6366f1", "#4d9ef5", "#2ed573", "#ff4757", "#a29bfe", "#ffa502", "#fd79a8", "#00cec9" };
                        var segments = BuildDonutSegments(_summary.CategoryBreakdown, total);
                    }

                    <div class="d-flex justify-center mb-4">
                        <svg viewBox="0 0 200 200" width="180" height="180" style="filter: drop-shadow(0 4px 24px rgba(0,0,0,0.4));">
                            <circle cx="100" cy="100" r="70" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="32" />
                            @foreach (var (seg, i) in segments.Select((s, i) => (s, i)))
                            {
                                <circle cx="100" cy="100" r="70"
                                        fill="none"
                                        stroke="@colors[i % colors.Length]"
                                        stroke-width="32"
                                        stroke-dasharray="@seg.Dash @seg.Gap"
                                        stroke-dashoffset="@seg.Offset"
                                        style="transform-origin: 100px 100px; opacity: 0.9;" />
                            }
                            <text x="100" y="94" text-anchor="middle"
                                  style="fill: var(--text-secondary); font-size: 9px; font-family: Pretendard;">
                                월 합계
                            </text>
                            <text x="100" y="112" text-anchor="middle"
                                  style="fill: var(--gold-400); font-size: 13px; font-weight: 800; font-family: Pretendard;">
                                ₩@FormatCompact(total)
                            </text>
                        </svg>
                    </div>

                    <!-- Legend -->
                    @foreach (var (cat, i) in _summary.CategoryBreakdown.Select((c, i) => (c, i)))
                    {
                        var pct = total > 0 ? (cat.MonthlyAmountKRW / total * 100) : 0;
                        <div class="d-flex align-center mb-2">
                            <div style="width:10px; height:10px; border-radius:3px; background:@colors[i % colors.Length]; flex-shrink:0;" class="mr-2"></div>
                            <MudText Typo="Typo.caption" Style="color: var(--text-secondary); flex-grow:1;">@cat.Category</MudText>
                            <MudText Typo="Typo.caption" Style="color: var(--text-primary); font-weight:600; margin-right:8px;">₩@cat.MonthlyAmountKRW.ToString("N0")</MudText>
                            <MudText Typo="Typo.caption" Style="color: var(--text-secondary);">@pct.ToString("F1")%</MudText>
                        </div>
                    }
                </div>
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    private DashboardSummary? _summary;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try { await LoadData(); }
        catch { _summary = GetMockData(); _loading = false; }
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        try { _summary = await ApiService.GetDashboardAsync(); }
        catch { _summary = GetMockData(); }
        _loading = false;
    }

    private string FormatCompact(decimal value)
    {
        if (value >= 10000) return $"{value / 10000:F0}만";
        return value.ToString("N0");
    }

    private record DonutSegment(double Dash, double Gap, double Offset);

    private List<DonutSegment> BuildDonutSegments(List<CategorySpend> categories, decimal total)
    {
        var result = new List<DonutSegment>();
        var circumference = 2 * Math.PI * 70;
        var offset = circumference * 0.25;

        foreach (var cat in categories)
        {
            var pct = total > 0 ? (double)(cat.MonthlyAmountKRW / total) : 0;
            var dash = pct * circumference;
            result.Add(new DonutSegment(dash, circumference - dash, offset));
            offset -= dash;
        }
        return result;
    }

    private DashboardSummary GetMockData() => new DashboardSummary
    {
        TotalMonthlyKRW = 145800,
        TotalYearlyKRW = 1749600,
        ActiveCount = 5,
        UpcomingBilling = new List<SubscriptionDto>
        {
            new() { Name="Spotify", Category="음악", Currency="USD", Amount=10.99m, AmountInKRW=15166, BillingCycle="MONTHLY", DaysUntilBilling=3, IconEmoji="🎵" },
            new() { Name="Netflix", Category="엔터테인먼트", Currency="KRW", Amount=17000, AmountInKRW=17000, BillingCycle="MONTHLY", DaysUntilBilling=5, IconEmoji="🎬" },
            new() { Name="Adobe CC", Category="창작 도구", Currency="USD", Amount=54.99m, AmountInKRW=75886, BillingCycle="MONTHLY", DaysUntilBilling=12, IconEmoji="🎨" },
            new() { Name="GitHub Copilot", Category="개발 도구", Currency="USD", Amount=10m, AmountInKRW=13800, BillingCycle="MONTHLY", DaysUntilBilling=20, IconEmoji="💻" },
            new() { Name="CLIP STUDIO", Category="창작 도구", Currency="KRW", Amount=4800, AmountInKRW=4800, BillingCycle="YEARLY", DaysUntilBilling=45, IconEmoji="✏️" },
        },
        CategoryBreakdown = new List<CategorySpend>
        {
            new() { Category="창작 도구", MonthlyAmountKRW=80286, Count=2 },
            new() { Category="엔터테인먼트", MonthlyAmountKRW=17000, Count=1 },
            new() { Category="개발 도구", MonthlyAmountKRW=13800, Count=1 },
            new() { Category="음악", MonthlyAmountKRW=15166, Count=1 },
        }
    };
}
