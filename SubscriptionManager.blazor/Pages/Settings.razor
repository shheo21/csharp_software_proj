@page "/settings"
@attribute [Authorize]
@inject IAuthService AuthService
@inject ICategoryService CategoryService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>설정 — SubTrack</PageTitle>

<div class="fade-in-up">
    <div class="d-flex align-center justify-space-between mb-6">
        <div>
            <div class="page-title">설정</div>
            <div class="page-subtitle">계정 · 카테고리를 관리합니다</div>
        </div>
    </div>

    <MudGrid Spacing="3">

        <MudItem xs="12" Class="fade-in-up fade-in-up-1">
            <div class="glass-card pa-5">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Person"
                             Style="color: var(--gold-400);" Class="mr-2" />
                    <MudText Typo="Typo.h6"
                             Style="font-weight:700; color: var(--text-primary);">
                        프로필
                    </MudText>
                </div>

                <div class="d-flex align-center pa-2 mb-3"
                     style="background: rgba(255,255,255,0.03); border-radius: 10px;">
                    <MudAvatar Color="Color.Primary" Size="Size.Medium" Class="mr-3">
                        @(_initial)
                    </MudAvatar>
                    <div style="min-width:0;">
                        <MudText Typo="Typo.subtitle1"
                                 Style="font-weight:700; color: var(--text-primary); line-height:1.2;">
                            @(string.IsNullOrWhiteSpace(_displayName) ? "사용자" : _displayName)
                        </MudText>
                        <MudText Typo="Typo.caption"
                                 Style="color: var(--text-secondary);">
                            @(string.IsNullOrWhiteSpace(_email) ? "로그인이 필요합니다" : _email)
                        </MudText>
                    </div>
                </div>

                <MudForm @ref="_profileForm" @bind-IsValid="_profileValid">
                    <div style="display:flex; align-items:flex-start; gap:16px; flex-wrap:wrap; max-width:760px;">
                        <div style="flex:1 1 420px; min-width:280px;">
                            <MudTextField T="string" @bind-Value="_displayName"
                                          Label="표시 이름" Variant="Variant.Outlined"
                                          Required="true" RequiredError="표시 이름을 입력하세요" />
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   Style="margin-top:10px; flex:0 0 auto;"
                                   Disabled="@(!_profileValid || _profileSaving)"
                                   OnClick="SaveProfile">
                            @(_profileSaving ? "저장 중..." : "표시 이름 저장")
                        </MudButton>
                    </div>
                </MudForm>

                <MudDivider Style="background-color: rgba(255,255,255,0.08); margin: 28px 0 22px;" />

                <MudGrid>
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2"
                                     Style="color: var(--text-secondary);">
                                비밀번호 변경
                            </MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField T="string" @bind-Value="_currentPassword"
                                          Label="현재 비밀번호" InputType="InputType.Password"
                                          Required="true" RequiredError="현재 비밀번호를 입력하세요"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField T="string" @bind-Value="_newPassword"
                                          Label="새 비밀번호" InputType="InputType.Password"
                                          Required="true" RequiredError="새 비밀번호를 입력하세요"
                                          Variant="Variant.Outlined"
                                          Validation="@(new Func<string, IEnumerable<string>>(ValidatePassword))" />
                        </MudItem>
                        <MudItem xs="12">
                            <div class="d-flex justify-end mt-2">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                           Disabled="@(!CanChangePassword || _passwordSaving)"
                                           OnClick="ChangePassword">
                                    @(_passwordSaving ? "변경 중..." : "비밀번호 변경")
                                </MudButton>
                            </div>
                        </MudItem>
                    </MudGrid>
            </div>
        </MudItem>

        <MudItem xs="12" Class="fade-in-up fade-in-up-2">
            <div class="glass-card pa-5">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.LocalOffer"
                             Style="color: var(--gold-400);" Class="mr-2" />
                    <MudText Typo="Typo.h6"
                             Style="font-weight:700; color: var(--text-primary);">
                        카테고리
                    </MudText>
                </div>

                @if (_categoriesLoading)
                {
                    <div class="d-flex justify-center pa-4">
                        <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                    </div>
                }
                else
                {
                    @if (CategoryService.Categories.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Style="color: var(--text-secondary);" Class="pa-4 text-center">
                            등록된 카테고리가 없습니다
                        </MudText>
                    }
                    else
                    {
                        @foreach (var cat in CategoryService.Categories)
                        {
                            <div class="category-item d-flex align-center pa-2 mb-2"
                                 style="background: rgba(255,255,255,0.04); border-radius: 8px;">
                                <MudIcon Icon="@Icons.Material.Filled.Label"
                                         Style="color: var(--text-secondary);"
                                         Class="mr-2" Size="Size.Small" />
                                <MudText Typo="Typo.body2"
                                         Style="color: var(--text-primary); flex:1;">@cat</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Default" Size="Size.Small"
                                               OnClick="@(() => DeleteCategory(cat))" />
                            </div>
                        }
                    }

                    <div class="d-flex align-center mt-3">
                        <MudTextField T="string" @bind-Value="_newCategory"
                                      Placeholder="새 카테고리 이름"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Immediate="true"
                                      Style="flex:1; margin-right: 8px;" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newCategory))"
                                   OnClick="AddCategory">
                            추가
                        </MudButton>
                    </div>
                }
            </div>
        </MudItem>

    </MudGrid>
</div>

@code {
    // 프로필
    private MudForm _profileForm = null!;
    private bool _profileValid;
    private bool _profileSaving;
    private bool _passwordSaving;
    private string _displayName = string.Empty;
    private string _email = string.Empty;
    private string _initial = "U";
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;

    // 카테고리 (CategoryService 가 공유 상태 보관)
    private bool _categoriesLoading = true;
    private string _newCategory = string.Empty;

    private bool CanChangePassword =>
        !string.IsNullOrWhiteSpace(_currentPassword) &&
        !string.IsNullOrWhiteSpace(_newPassword) &&
        _newPassword.Length >= 8;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
        await LoadCategoriesAsync();
        CategoryService.OnChange += OnCategoriesChanged;
    }

    private void OnCategoriesChanged() => InvokeAsync(StateHasChanged);
    
    public void Dispose()
    {
        CategoryService.OnChange -= OnCategoriesChanged;
    }

    private async Task LoadProfileAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        if (user != null)
        {
            _displayName = user.DisplayName;
            _email = user.Email;
            _initial = !string.IsNullOrWhiteSpace(user.DisplayName)
                ? user.DisplayName.Substring(0, 1).ToUpperInvariant()
                : "U";
        }
    }

    private async Task LoadCategoriesAsync()
    {
        _categoriesLoading = true;
        try { await CategoryService.EnsureLoadedAsync(); }
        finally { _categoriesLoading = false; }
    }

    private IEnumerable<string> ValidatePassword(string? password)
    {
        if (string.IsNullOrEmpty(password)) yield break; 
        if (password.Length < 8) yield return "비밀번호는 8자 이상이어야 합니다";
    }

    private async Task SaveProfile()
    {
        if (_profileForm != null)
        {
            await _profileForm.ValidateAsync();
        }

        if (!_profileValid)
        {
            return;
        }

        _profileSaving = true;
        try
        {
            var result = await AuthService.UpdateProfileAsync(new UpdateProfileRequest
            {
                DisplayName = _displayName
            });

            if (!result.Success)
            {
                Snackbar.Add(result.Error ?? "프로필 저장에 실패했습니다.", Severity.Error);
                return;
            }

            _displayName = _displayName.Trim();
            _initial = !string.IsNullOrWhiteSpace(_displayName)
                ? _displayName.Substring(0, 1).ToUpperInvariant()
                : "U";
            Snackbar.Add("프로필이 저장되었습니다", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"저장 실패: {ex.Message}", Severity.Error); }
        finally { _profileSaving = false; }
    }

    private async Task ChangePassword()
    {
        if (string.IsNullOrWhiteSpace(_currentPassword) ||
            string.IsNullOrWhiteSpace(_newPassword))
        {
            Snackbar.Add("현재 비밀번호와 새 비밀번호를 입력하세요", Severity.Warning);
            return;
        }

        if (_newPassword.Length < 8)
        {
            Snackbar.Add("비밀번호는 8자 이상이어야 합니다", Severity.Warning);
            return;
        }

        _passwordSaving = true;
        try
        {
            var result = await AuthService.ChangePasswordAsync(new ChangePasswordRequest
            {
                CurrentPassword = _currentPassword,
                NewPassword = _newPassword
            });

            if (!result.Success)
            {
                Snackbar.Add(result.Error ?? "비밀번호 변경에 실패했습니다.", Severity.Error);
                return;
            }

            _currentPassword = string.Empty;
            _newPassword = string.Empty;
            Snackbar.Add("비밀번호가 변경되었습니다", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"변경 실패: {ex.Message}", Severity.Error); }
        finally { _passwordSaving = false; }
    }

    private async Task AddCategory()
    {
        var name = _newCategory?.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        if (CategoryService.Categories.Contains(name))
        {
            Snackbar.Add("이미 존재하는 카테고리입니다", Severity.Warning);
            return;
        }
        await CategoryService.AddAsync(name);
        _newCategory = string.Empty;
    }

    private async Task DeleteCategory(string name)
    {
        await CategoryService.RemoveAsync(name);
    }

}
