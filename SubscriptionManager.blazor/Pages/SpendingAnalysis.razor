@page "/spending-analysis"
@inject ISubscriptionApiService ApiService

<PageTitle>지출 분석 — SubTrack</PageTitle>

<div class="fade-in-up">
    <!-- Header -->
    <div class="d-flex align-center justify-space-between mb-6">
        <div>
            <div class="page-title">지출 분석</div>
            <div class="page-subtitle">카테고리별 · 월별 지출 추이 분석</div>
        </div>
        <MudButton Variant="Variant.Outlined"
                   Style="border-radius:12px; font-weight:600; border-color:var(--border-subtle); color:var(--text-secondary);"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadData">
            새로고침
        </MudButton>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center pa-16">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else if (_data != null)
    {
        <!-- KPI Cards -->
        <MudGrid Spacing="3" Class="mb-5">
            <MudItem xs="12" sm="6" md="3" Class="fade-in-up fade-in-up-1">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px; position:relative; overflow:hidden;">
                    <div style="position:absolute;top:-20px;right:-20px;width:100px;height:100px;
                                border-radius:50%;background:radial-gradient(circle,rgba(99,102,241,0.1),transparent);"></div>
                    <div class="stat-label mb-2">이번 달 지출</div>
                    <div class="stat-value" style="color:var(--gold-400);">
                        ₩@_data.TotalMonthlyKRW.ToString("N0")
                    </div>
                    <MudText Typo="Typo.caption" Style="color:var(--text-secondary);margin-top:4px;">
                        월 환산 기준
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" md="3" Class="fade-in-up fade-in-up-2">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px;">
                    <div class="stat-label mb-2">연간 예상 지출</div>
                    <div class="stat-value">₩@_data.TotalYearlyKRW.ToString("N0")</div>
                    <MudText Typo="Typo.caption" Style="color:var(--accent-blue);margin-top:4px;">
                        12개월 추정
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" md="3" Class="fade-in-up fade-in-up-3">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px;">
                    <div class="stat-label mb-2">평균 월 지출</div>
                    <div class="stat-value" style="color:var(--accent-green);">
                        ₩@_data.AverageMonthlyKRW.ToString("N0")
                    </div>
                    <MudText Typo="Typo.caption" Style="color:var(--text-secondary);margin-top:4px;">
                        최근 @(_selectedMonths)개월 평균
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" md="3" Class="fade-in-up fade-in-up-4">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px;">
                    <div class="stat-label mb-2">최다 지출 카테고리</div>
                    <div class="stat-value" style="color:var(--accent-orange); font-size:1.4rem;">
                        @_data.TopCategory
                    </div>
                    <MudText Typo="Typo.caption" Style="color:var(--text-secondary);margin-top:4px;">
                        @(_data.ActiveCount)개 구독 중
                    </MudText>
                </div>
            </MudItem>
        </MudGrid>

        <!-- Row: Donut + Trend Chart -->
        <MudGrid Spacing="3" Class="mb-5">

            <!-- Detailed Donut Chart -->
            <MudItem xs="12" md="5" Class="fade-in-up fade-in-up-2">
                <div class="glass-card pa-5" style="height:100%;">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.DonutSmall" Style="color:var(--gold-400);" Class="mr-2" />
                        <MudText Typo="Typo.h6" Style="font-weight:700;color:var(--text-primary);">카테고리별 지출</MudText>
                    </div>

                    @{
                        var total = _data.CategoryBreakdown.Sum(c => c.MonthlyAmountKRW);
                        var colors = new[] { "#6366f1","#4d9ef5","#2ed573","#ff4757","#a29bfe","#ffa502","#fd79a8","#00cec9","#55efc4","#e17055" };
                        var segments = BuildDonutSegments(_data.CategoryBreakdown, total);
                    }

                    <div class="d-flex justify-center mb-4">
                        <svg viewBox="0 0 220 220" width="200" height="200"
                             style="filter:drop-shadow(0 4px 24px rgba(0,0,0,0.5));">
                            <circle cx="110" cy="110" r="80" fill="none"
                                    stroke="rgba(255,255,255,0.04)" stroke-width="36" />
                            @foreach (var (seg, i) in segments.Select((s, i) => (s, i)))
                            {
                                <circle cx="110" cy="110" r="80"
                                        fill="none"
                                        stroke="@colors[i % colors.Length]"
                                        stroke-width="36"
                                        stroke-dasharray="@seg.Dash @seg.Gap"
                                        stroke-dashoffset="@seg.Offset"
                                        style="transform-origin:110px 110px; opacity:0.9; cursor:pointer;"
                                        class="donut-seg" />
                            }
                            @((MarkupString)$"""
                                <text x="110" y="103" text-anchor="middle"
                                      style="fill:var(--text-secondary);font-size:9px;font-family:Pretendard;">월 합계</text>
                                <text x="110" y="120" text-anchor="middle"
                                      style="fill:var(--gold-400);font-size:14px;font-weight:800;font-family:Pretendard;">₩{FormatCompact(total)}</text>
                                <text x="110" y="133" text-anchor="middle"
                                      style="fill:var(--text-secondary);font-size:8px;font-family:Pretendard;">{_data.CategoryBreakdown.Count}개 카테고리</text>
                            """)
                        </svg>
                    </div>

                    @foreach (var (cat, i) in _data.CategoryBreakdown.Select((c, i) => (c, i)))
                    {
                        var pct = total > 0 ? (cat.MonthlyAmountKRW / total * 100) : 0;
                        <div class="d-flex align-center mb-2 py-1"
                             style="border-bottom:1px solid rgba(255,255,255,0.04);">
                            <div style="width:12px;height:12px;border-radius:3px;
                                        background:@colors[i % colors.Length];flex-shrink:0;" class="mr-2"></div>
                            <MudText Typo="Typo.body2"
                                     Style="color:var(--text-secondary);flex-grow:1;font-size:0.82rem;">
                                @cat.Category
                            </MudText>
                            <MudText Typo="Typo.caption"
                                     Style="color:var(--text-secondary);margin-right:8px;font-size:0.75rem;">
                                @(cat.Count)개
                            </MudText>
                            <MudText Typo="Typo.body2"
                                     Style="color:var(--text-primary);font-weight:600;margin-right:8px;font-size:0.85rem;min-width:70px;text-align:right;">
                                ₩@cat.MonthlyAmountKRW.ToString("N0")
                            </MudText>
                            <div style="width:60px;">
                                <div style="background:rgba(255,255,255,0.06);border-radius:10px;height:5px;overflow:hidden;">
                                    <div style="width:@((double)pct)%;height:100%;border-radius:10px;
                                                background:@colors[i % colors.Length];opacity:0.8;"></div>
                                </div>
                                <div style="font-size:0.68rem;color:var(--text-secondary);text-align:right;margin-top:1px;">
                                    @pct.ToString("F1")%
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </MudItem>

            <!-- Monthly Trend Chart -->
            <MudItem xs="12" md="7" Class="fade-in-up fade-in-up-3">
                <div class="glass-card pa-5" style="height:100%;">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="color:var(--gold-400);" Class="mr-2" />
                        <MudText Typo="Typo.h6" Style="font-weight:700;color:var(--text-primary);">월별 지출 추이</MudText>
                        <MudSpacer />
                        <div style="display:flex;background:rgba(255,255,255,0.04);
                                    border:1px solid rgba(255,255,255,0.08);border-radius:10px;overflow:hidden;">
                            <div @onclick='() => SetMonths(6)'
                                 style="padding:5px 14px;font-size:0.78rem;font-weight:600;cursor:pointer;transition:all 0.2s;
                                        @(_selectedMonths == 6 ? "background:rgba(99,102,241,0.15);color:var(--gold-400);" : "color:var(--text-secondary);")"
                                 class="period-btn">
                                6개월
                            </div>
                            <div @onclick='() => SetMonths(12)'
                                 style="padding:5px 14px;font-size:0.78rem;font-weight:600;cursor:pointer;transition:all 0.2s;
                                        @(_selectedMonths == 12 ? "background:rgba(99,102,241,0.15);color:var(--gold-400);" : "color:var(--text-secondary);")"
                                 class="period-btn">
                                12개월
                            </div>
                        </div>
                    </div>

                    @((MarkupString)BuildTrendChartSvg(_data.MonthlyTrends, _selectedMonths))

                    @{
                        var visibleTrends = _data.MonthlyTrends.TakeLast(_selectedMonths).ToList();
                    }
                    @if (visibleTrends.Count > 0)
                    {
                        var highest = visibleTrends.OrderByDescending(t => t.TotalKRW).First();
                        var lowest = visibleTrends.Where(t => t.TotalKRW > 0).OrderBy(t => t.TotalKRW).FirstOrDefault();
                        <div class="d-flex gap-4 mt-3 pt-3" style="border-top:1px solid rgba(255,255,255,0.06);">
                            <div>
                                <div style="font-size:0.72rem;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.05em;">최고</div>
                                <div style="font-size:0.88rem;font-weight:700;color:var(--accent-red);">₩@highest.TotalKRW.ToString("N0")</div>
                                <div style="font-size:0.72rem;color:var(--text-secondary);">@highest.Label</div>
                            </div>
                            @if (lowest != null)
                            {
                                <div>
                                    <div style="font-size:0.72rem;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.05em;">최저</div>
                                    <div style="font-size:0.88rem;font-weight:700;color:var(--accent-green);">₩@lowest.TotalKRW.ToString("N0")</div>
                                    <div style="font-size:0.72rem;color:var(--text-secondary);">@lowest.Label</div>
                                </div>
                            }
                            <div>
                                <div style="font-size:0.72rem;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.05em;">평균</div>
                                <div style="font-size:0.88rem;font-weight:700;color:var(--gold-400);">₩@((visibleTrends.Average(t => (double)t.TotalKRW)).ToString("N0"))</div>
                                <div style="font-size:0.72rem;color:var(--text-secondary);">@(_selectedMonths)개월</div>
                            </div>
                        </div>
                    }
                </div>
            </MudItem>
        </MudGrid>

        <!-- Category Detail Table -->
        <div class="glass-card pa-5 fade-in-up fade-in-up-4">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.TableChart" Style="color:var(--gold-400);" Class="mr-2" />
                <MudText Typo="Typo.h6" Style="font-weight:700;color:var(--text-primary);">카테고리 상세</MudText>
                <MudSpacer />
                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                         Style="background:rgba(99,102,241,0.1);color:var(--gold-400);font-size:0.72rem;">
                    @(_data.CategoryBreakdown.Count)개 카테고리
                </MudChip>
            </div>

            @{
                var catTotal = _data.CategoryBreakdown.Sum(c => c.MonthlyAmountKRW);
                var catColors = new[] { "#6366f1","#4d9ef5","#2ed573","#ff4757","#a29bfe","#ffa502","#fd79a8","#00cec9","#55efc4","#e17055" };
            }

            <MudTable Items="@_data.CategoryBreakdown" Hover="true" Dense="false"
                      Style="background:transparent;" Elevation="0">
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel SortBy='new Func<CategorySpend, object>(x => x.Category)'>
                            카테고리
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>구독 수</MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy='new Func<CategorySpend, object>(x => x.MonthlyAmountKRW)'
                                          InitialDirection="SortDirection.Descending">
                            월 지출
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>연간 지출</MudTh>
                    <MudTh>비중</MudTh>
                    <MudTh>비중 시각화</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var rowIdx = _data.CategoryBreakdown.IndexOf(context);
                        var rowColor = catColors[rowIdx % catColors.Length];
                        var rowPct = catTotal > 0 ? (double)(context.MonthlyAmountKRW / catTotal * 100) : 0;
                    }
                    <MudTd>
                        <div class="d-flex align-center gap-2">
                            <div style="width:10px;height:10px;border-radius:3px;
                                        background:@rowColor;flex-shrink:0;"></div>
                            <span style="font-weight:600;color:var(--text-primary);">@context.Category</span>
                        </div>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                 Style="background:rgba(255,255,255,0.06);color:var(--text-secondary);font-size:0.75rem;">
                            @(context.Count)개
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <span style="font-weight:700;color:var(--gold-400);">
                            ₩@context.MonthlyAmountKRW.ToString("N0")
                        </span>
                    </MudTd>
                    <MudTd>
                        <span style="color:var(--text-secondary);">
                            ₩@((context.MonthlyAmountKRW * 12).ToString("N0"))
                        </span>
                    </MudTd>
                    <MudTd>
                        <span style="font-weight:600;color:@rowColor;">
                            @rowPct.ToString("F1")%
                        </span>
                    </MudTd>
                    <MudTd>
                        <div style="width:140px;">
                            <div style="background:rgba(255,255,255,0.06);border-radius:10px;height:6px;overflow:hidden;">
                                <div style="width:@rowPct%;height:100%;border-radius:10px;
                                            background:@rowColor;transition:width 0.6s ease;"></div>
                            </div>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    }
</div>

<style>
    .donut-seg:hover { stroke-width: 42px !important; }
    .period-btn:hover { background: rgba(255,255,255,0.06) !important; }
</style>

@code {
    private SpendingTrendsDto? _data;
    private bool _loading = true;
    private int _selectedMonths = 12;

    protected override async Task OnInitializedAsync()
    {
        try { await LoadData(); }
        catch { _data = GetMockData(); _loading = false; }
    }

    private async Task SetMonths(int months)
    {
        _selectedMonths = months;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _data = await ApiService.GetSpendingTrendsAsync(_selectedMonths);
        }
        catch
        {
            _data = GetMockData();
        }
        _loading = false;
    }

    private string FormatCompact(decimal value)
    {
        if (value >= 10000) return $"{value / 10000:F0}만";
        return value.ToString("N0");
    }

    private record DonutSegment(double Dash, double Gap, double Offset);

    private List<DonutSegment> BuildDonutSegments(List<CategorySpend> categories, decimal total)
    {
        var result = new List<DonutSegment>();
        var circumference = 2 * Math.PI * 80;
        var offset = circumference * 0.25;
        foreach (var cat in categories)
        {
            var pct = total > 0 ? (double)(cat.MonthlyAmountKRW / total) : 0;
            var dash = pct * circumference;
            result.Add(new DonutSegment(dash, circumference - dash, offset));
            offset -= dash;
        }
        return result;
    }

    private string BuildTrendChartSvg(List<MonthlyTrend> allTrends, int months)
    {
        var trends = allTrends.TakeLast(months).ToList();
        if (trends.Count == 0) return "<svg></svg>";

        var maxVal = (double)trends.Max(t => t.TotalKRW);
        if (maxVal == 0) maxVal = 1;
        var chartW = 560;
        var chartH = 200;
        var barCount = trends.Count;
        var barGap = 8;
        var barW = (chartW - barGap * (barCount + 1)) / barCount;
        var currentMonth = DateTime.Now.ToString("yyyy-MM");
        var fontSize = months == 12 ? 7 : 8;

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 -10 {chartW} {chartH + 60}\" width=\"100%\" style=\"overflow:visible;\">");

        sb.Append("""
            <defs>
                <linearGradient id="barGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#6366f1" stop-opacity="0.8"/>
                    <stop offset="100%" stop-color="#6366f1" stop-opacity="0.2"/>
                </linearGradient>
                <linearGradient id="barGradCurrent" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#a5b4fc" stop-opacity="1"/>
                    <stop offset="100%" stop-color="#6366f1" stop-opacity="0.5"/>
                </linearGradient>
            </defs>
        """);

        for (int g = 0; g <= 4; g++)
        {
            var yVal = maxVal * g / 4;
            var yPos = chartH - (chartH * g / 4);
            sb.Append($"<line x1=\"0\" y1=\"{yPos}\" x2=\"{chartW}\" y2=\"{yPos}\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\"/>");
            sb.Append($"<text x=\"-6\" y=\"{yPos + 4}\" text-anchor=\"end\" style=\"fill:var(--text-secondary);font-size:8px;font-family:Pretendard;\">{FormatCompact((decimal)yVal)}</text>");
        }

        for (int i = 0; i < trends.Count; i++)
        {
            var trend = trends[i];
            var barH = (double)trend.TotalKRW / maxVal * chartH;
            var x = barGap + i * (barW + barGap);
            var y = chartH - barH;
            var isCurrent = trend.Month == currentMonth;
            var fill = isCurrent ? "url(#barGradCurrent)" : "url(#barGrad)";
            var labelColor = isCurrent ? "var(--gold-400)" : "var(--text-secondary)";
            var labelWeight = isCurrent ? "700" : "400";
            var valColor = isCurrent ? "var(--gold-300)" : "var(--text-secondary)";

            sb.Append($"<rect x=\"{x}\" y=\"{y:F1}\" width=\"{barW}\" height=\"{(barH > 0 ? barH : 0):F1}\" fill=\"{fill}\" rx=\"4\" style=\"transition:opacity 0.2s;\"/>");

            if (barH > 20)
                sb.Append($"<text x=\"{x + barW / 2}\" y=\"{y - 5:F1}\" text-anchor=\"middle\" style=\"fill:{valColor};font-size:7px;font-family:Pretendard;font-weight:{labelWeight};\">₩{FormatCompact(trend.TotalKRW)}</text>");

            sb.Append($"<text x=\"{x + barW / 2}\" y=\"{chartH + 16}\" text-anchor=\"middle\" style=\"fill:{labelColor};font-size:{fontSize}px;font-family:Pretendard;font-weight:{labelWeight};\">{trend.Label}</text>");
        }

        sb.Append($"<line x1=\"0\" y1=\"{chartH}\" x2=\"{chartW}\" y2=\"{chartH}\" stroke=\"rgba(255,255,255,0.1)\" stroke-width=\"1\"/>");
        sb.Append("</svg>");
        return sb.ToString();
    }

    private SpendingTrendsDto GetMockData()
    {
        var now = DateTime.Now;
        var rng = new Random(42);
        var trends = Enumerable.Range(0, _selectedMonths)
            .Select(i =>
            {
                var month = new DateTime(now.Year, now.Month, 1).AddMonths(-(_selectedMonths - 1 - i));
                var isYearlyMonth = i % 12 == 0;
                var baseAmt = 89400m + (isYearlyMonth ? 75840m : 0m);
                return new MonthlyTrend
                {
                    Month = month.ToString("yyyy-MM"),
                    Label = month.ToString("yy년 M월"),
                    TotalKRW = baseAmt + (decimal)(rng.NextDouble() * 5000 - 2500),
                    ByCategory = new List<CategoryMonthlyAmount>
                    {
                        new() { Category = "창작 도구", AmountKRW = 75840 },
                        new() { Category = "엔터테인먼트", AmountKRW = 22060 },
                        new() { Category = "음악", AmountKRW = 13790 },
                    }
                };
            }).ToList();

        return new SpendingTrendsDto
        {
            MonthlyTrends = trends,
            TotalMonthlyKRW = 89400,
            TotalYearlyKRW = 1072800,
            ActiveCount = 6,
            TopCategory = "창작 도구",
            AverageMonthlyKRW = (decimal)trends.Average(t => (double)t.TotalKRW),
            CategoryBreakdown = new List<CategorySpend>
            {
                new() { Category = "창작 도구", MonthlyAmountKRW = 75840, Count = 2 },
                new() { Category = "엔터테인먼트", MonthlyAmountKRW = 22060, Count = 1 },
                new() { Category = "음악", MonthlyAmountKRW = 13790, Count = 1 },
                new() { Category = "개발 도구", MonthlyAmountKRW = 6210, Count = 1 },
                new() { Category = "클라우드 스토리지", MonthlyAmountKRW = 3300, Count = 1 },
            }
        };
    }
}
