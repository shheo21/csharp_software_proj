        font-size: 0.78rem;
        line-height: 1.35;
    }

    .donut-seg:hover { stroke-width: 42px !important; }

    @@media (max-width: 1200px) {
        .category-breakdown-row {
            grid-template-columns: 12px minmax(0, 1fr) 38px 92px;
            row-gap: 6px;
        }

        .category-share {
            grid-column: 2 / -1;
            width: 100%;
        }
    }

    @@media (max-width: 600px) {
        .spending-chart-card {
            min-height: auto;
        }

        .analysis-card-header {
            flex-wrap: wrap;
        }

        .spending-page-actions {
            width: 100%;
            justify-content: flex-start;
        }

        .period-control {
            width: 100%;
            flex-wrap: wrap;
        }

        .category-breakdown-row {
            grid-template-columns: 12px minmax(0, 1fr) 38px 90px;
            row-gap: 6px;
        }

        .trend-summary {
            gap: 18px;
        }
    }
</style>

@code {
    private static readonly int[] PresetMonths = new[] { 1, 3, 6, 12 };

    private SpendingTrendsDto? _data;
    private bool _loading = true;
    private int _selectedMonths = 12;
    private int _customMonths = 12;

    private bool IsCustomPeriod => !PresetMonths.Contains(_selectedMonths);

    protected override async Task OnInitializedAsync()
    {
        try { await LoadData(); }
        catch { _data = GetMockData(); _loading = false; }
    }

    private async Task SetMonths(int months)
    {
        _selectedMonths = NormalizeMonths(months);
        _customMonths = _selectedMonths;
        await LoadData();
    }

    private async Task ApplyCustomMonths(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var months))
        {
            _customMonths = _selectedMonths;
            return;
        }

        await SetMonths(months);
    }

    private string GetPeriodButtonClass(int months) =>
        _selectedMonths == months ? "active" : string.Empty;

    private static int NormalizeMonths(int months) => Math.Clamp(months, 1, 24);

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _data = await ApiService.GetSpendingTrendsAsync(_selectedMonths);
        }
        catch
        {
            _data = GetMockData();
        }

        await CategoryService.EnsureLoadedAsync(_data.CategoryBreakdown.Select(c => c.Category));
        _loading = false;
    }

    private string FormatCompact(decimal value)
    {
        if (value >= 10000) return $"{value / 10000:F0}만";
        return value.ToString("N0");
    }

    private record DonutSegment(double Dash, double Gap, double Offset);

    private List<DonutSegment> BuildDonutSegments(List<CategorySpend> categories, decimal total)
    {
        var result = new List<DonutSegment>();
        var circumference = 2 * Math.PI * 80;
        var offset = circumference * 0.25;
        foreach (var cat in categories)
        {
            var pct = total > 0 ? (double)(cat.MonthlyAmountKRW / total) : 0;
            var dash = pct * circumference;
            result.Add(new DonutSegment(dash, circumference - dash, offset));
            offset -= dash;
        }
        return result;
    }

    private string BuildTrendChartSvg(List<MonthlyTrend> allTrends, int months)
    {
        var trends = allTrends.TakeLast(months).ToList();
        if (trends.Count == 0) return "<svg></svg>";

        var maxVal = (double)trends.Max(t => t.TotalKRW);
        if (maxVal == 0) maxVal = 1;
        var plotW = 560;
        var plotH = 220;
        var marginLeft = 42;
        var marginRight = 14;
        var marginTop = 22;
        var marginBottom = months > 12 ? 64 : 38;
        var svgW = marginLeft + plotW + marginRight;
        var svgH = marginTop + plotH + marginBottom;
        var barCount = trends.Count;
        var barGap = months > 12 ? 6d : months == 12 ? 10d : 16d;
        var barW = (plotW - barGap * (barCount + 1)) / barCount;
        var currentMonth = DateTime.Now.ToString("yyyy-MM");
        var xAxisFontSize = months > 12 ? 8 : months == 12 ? 9 : 10;
        var yAxisFontSize = 10;
        var valueFontSize = 9;
        var rotateMonthLabels = months > 12;

        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {svgW} {svgH}\" width=\"100%\" class=\"trend-chart-svg\">");

        sb.Append("""
            <defs>
                <linearGradient id="barGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#6366f1" stop-opacity="0.8"/>
                    <stop offset="100%" stop-color="#6366f1" stop-opacity="0.2"/>
                </linearGradient>
                <linearGradient id="barGradCurrent" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#a5b4fc" stop-opacity="1"/>
                    <stop offset="100%" stop-color="#6366f1" stop-opacity="0.5"/>
                </linearGradient>
            </defs>
        """);

        for (int g = 0; g <= 4; g++)
        {
            var yVal = maxVal * g / 4;
            var yPos = marginTop + plotH - (plotH * g / 4);
            sb.Append($"<line x1=\"{marginLeft}\" y1=\"{yPos}\" x2=\"{marginLeft + plotW}\" y2=\"{yPos}\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1\"/>");
            sb.Append($"<text x=\"{marginLeft - 10}\" y=\"{yPos + 4}\" text-anchor=\"end\" style=\"fill:var(--text-secondary);font-size:{yAxisFontSize}px;font-family:Pretendard;font-weight:500;\">{FormatCompact((decimal)yVal)}</text>");
        }

        for (int i = 0; i < trends.Count; i++)
        {
            var trend = trends[i];
            var barH = (double)trend.TotalKRW / maxVal * plotH;
            var x = marginLeft + barGap + i * (barW + barGap);
            var y = marginTop + plotH - barH;
            var isCurrent = trend.Month == currentMonth;
            var fill = isCurrent ? "url(#barGradCurrent)" : "url(#barGrad)";
            var labelColor = isCurrent ? "var(--gold-400)" : "var(--text-secondary)";
            var labelWeight = isCurrent ? "700" : "400";
            var valColor = isCurrent ? "var(--gold-300)" : "var(--text-secondary)";
            var labelX = x + barW / 2;
            var labelY = marginTop + plotH + 24;

            sb.Append($"<rect x=\"{x}\" y=\"{y:F1}\" width=\"{barW}\" height=\"{(barH > 0 ? barH : 0):F1}\" fill=\"{fill}\" rx=\"4\" style=\"transition:opacity 0.2s;\"/>");

            if (barH > 24 && (months <= 12 || isCurrent))
                sb.Append($"<text x=\"{x + barW / 2}\" y=\"{Math.Max(12, y - 7):F1}\" text-anchor=\"middle\" style=\"fill:{valColor};font-size:{valueFontSize}px;font-family:Pretendard;font-weight:{labelWeight};\">₩{FormatCompact(trend.TotalKRW)}</text>");

            if (rotateMonthLabels)
            {
                sb.Append($"<text x=\"{labelX}\" y=\"{labelY}\" text-anchor=\"end\" transform=\"rotate(-45 {labelX} {labelY})\" style=\"fill:{labelColor};font-size:{xAxisFontSize}px;font-family:Pretendard;font-weight:{labelWeight};\">{trend.Label}</text>");
            }
            else
            {
                sb.Append($"<text x=\"{labelX}\" y=\"{labelY}\" text-anchor=\"middle\" style=\"fill:{labelColor};font-size:{xAxisFontSize}px;font-family:Pretendard;font-weight:{labelWeight};\">{trend.Label}</text>");
            }
        }

        sb.Append($"<line x1=\"{marginLeft}\" y1=\"{marginTop + plotH}\" x2=\"{marginLeft + plotW}\" y2=\"{marginTop + plotH}\" stroke=\"rgba(255,255,255,0.1)\" stroke-width=\"1\"/>");
        sb.Append("</svg>");
        return sb.ToString();
    }

    private SpendingTrendsDto GetMockData()
    {
        var now = DateTime.Now;
        var rng = new Random(42);
        var trends = Enumerable.Range(0, _selectedMonths)
            .Select(i =>
            {
                var month = new DateTime(now.Year, now.Month, 1).AddMonths(-(_selectedMonths - 1 - i));
                var isYearlyMonth = i % 12 == 0;
                var baseAmt = 89400m + (isYearlyMonth ? 75840m : 0m);
                return new MonthlyTrend
                {
                    Month = month.ToString("yyyy-MM"),
                    Label = month.ToString("yy년 M월"),
                    TotalKRW = baseAmt + (decimal)(rng.NextDouble() * 5000 - 2500),
                    ByCategory = new List<CategoryMonthlyAmount>
                    {
                        new() { Category = "창작 도구", AmountKRW = 75840 },
                        new() { Category = "엔터테인먼트", AmountKRW = 22060 },
                        new() { Category = "음악", AmountKRW = 13790 },
                    }
                };
            }).ToList();

        return new SpendingTrendsDto
        {
            MonthlyTrends = trends,
            TotalMonthlyKRW = 89400,
            TotalYearlyKRW = 1072800,
            ActiveCount = 6,
            TopCategory = "창작 도구",
            AverageMonthlyKRW = (decimal)trends.Average(t => (double)t.TotalKRW),
            CategoryBreakdown = new List<CategorySpend>
            {
                new() { Category = "창작 도구", MonthlyAmountKRW = 75840, Count = 2 },
                new() { Category = "엔터테인먼트", MonthlyAmountKRW = 22060, Count = 1 },
                new() { Category = "음악", MonthlyAmountKRW = 13790, Count = 1 },
                new() { Category = "개발 도구", MonthlyAmountKRW = 6210, Count = 1 },
                new() { Category = "클라우드 스토리지", MonthlyAmountKRW = 3300, Count = 1 },
            }
        };
    }
