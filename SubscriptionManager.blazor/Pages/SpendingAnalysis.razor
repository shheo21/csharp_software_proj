        flex-wrap: wrap;
        gap: 48px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .trend-summary-item {
        min-width: 86px;
    }

    .trend-summary-label {
        color: var(--text-secondary);
        font-size: 0.78rem;
        font-weight: 600;
        line-height: 1.35;
    }

    .trend-summary-value {
        font-size: 1.02rem;
