@page "/spending-analysis"
@attribute [Authorize]
@inject ISubscriptionApiService ApiService
@inject ICategoryService CategoryService

<PageTitle>지출 분석 — SubTrack</PageTitle>

<div class="fade-in-up">
    <!-- Header -->
    <div class="spending-page-header mb-6">
        <div>
            <div class="page-title">지출 분석</div>
            <div class="page-subtitle">카테고리별 · 월별 지출 추이 분석</div>
        </div>
        <div class="spending-page-actions">
            <div class="period-control" aria-label="분석 기간 선택">
                <button type="button"
                        class="period-option @GetPeriodButtonClass(1)"
                        @onclick="() => SetMonths(1)">
                    1개월
                </button>
                <button type="button"
                        class="period-option @GetPeriodButtonClass(3)"
                        @onclick="() => SetMonths(3)">
                    3개월
                </button>
                <button type="button"
                        class="period-option @GetPeriodButtonClass(6)"
                        @onclick="() => SetMonths(6)">
                    6개월
                </button>
                <button type="button"
                        class="period-option @GetPeriodButtonClass(12)"
                        @onclick="() => SetMonths(12)">
                    12개월
                </button>
                <label class="custom-period-entry @(IsCustomPeriod ? "active" : null)">
                    <span class="custom-period-label">직접</span>
                    <input class="custom-period-input"
                           type="number"
                           min="1"
                           max="24"
                           value="@_customMonths"
                           @onchange="ApplyCustomMonths" />
                    <span>개월</span>
                </label>
            </div>
            <MudButton Variant="Variant.Outlined"
                       Style="border-radius:12px; font-weight:600; border-color:var(--border-subtle); color:var(--text-secondary);"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadData">
                새로고침
            </MudButton>
        </div>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center pa-16">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else if (_data != null)
    {
        <!-- KPI Cards -->
        <MudGrid Spacing="3" Class="mb-5">
            <MudItem xs="12" sm="6" md="6" lg="3" Class="fade-in-up fade-in-up-1">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px; position:relative; overflow:hidden;">
                    <div style="position:absolute;top:-20px;right:-20px;width:100px;height:100px;
                                border-radius:50%;background:radial-gradient(circle,rgba(99,102,241,0.1),transparent);"></div>
                    <div class="stat-label mb-2">이번 달 지출</div>
                    <div class="stat-value" style="color:var(--gold-400);">
                        ₩@_data.TotalMonthlyKRW.ToString("N0")
                    </div>
                    <MudText Typo="Typo.caption" Style="color:var(--text-secondary);margin-top:4px;">
                        월 환산 기준
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" md="6" lg="3" Class="fade-in-up fade-in-up-2">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px;">
                    <div class="stat-label mb-2">연간 예상 지출</div>
                    <div class="stat-value">₩@_data.TotalYearlyKRW.ToString("N0")</div>
                    <MudText Typo="Typo.caption" Style="color:var(--accent-blue);margin-top:4px;">
                        12개월 추정
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" md="6" lg="3" Class="fade-in-up fade-in-up-3">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px;">
                    <div class="stat-label mb-2">평균 월 지출</div>
                    <div class="stat-value" style="color:var(--accent-green);">
                        ₩@_data.AverageMonthlyKRW.ToString("N0")
                    </div>
                    <MudText Typo="Typo.caption" Style="color:var(--text-secondary);margin-top:4px;">
                        최근 @(_selectedMonths)개월 평균
                    </MudText>
                </div>
            </MudItem>

            <MudItem xs="12" sm="6" md="6" lg="3" Class="fade-in-up fade-in-up-4">
                <div class="stat-card pa-5 d-flex flex-column" style="min-height:120px;">
                    <div class="stat-label mb-2">최다 지출 카테고리</div>
                    <div class="stat-value" style="color:var(--accent-orange); font-size:1.4rem;">
                        @_data.TopCategory
                    </div>
                    <MudText Typo="Typo.caption" Style="color:var(--text-secondary);margin-top:4px;">
                        @(_data.ActiveCount)개 구독 중
                    </MudText>
                </div>
            </MudItem>
        </MudGrid>

        <!-- Row: Donut + Trend Chart -->
        <MudGrid Spacing="3" Class="mb-5">

            <!-- Detailed Donut Chart -->
            <MudItem xs="12" lg="5" Class="fade-in-up fade-in-up-2">
                <div class="glass-card pa-5 spending-chart-card">
                    <div class="d-flex align-center mb-4 analysis-card-header">
                        <MudIcon Icon="@Icons.Material.Filled.DonutSmall" Style="color:var(--gold-400);" Class="mr-2" />
                        <MudText Typo="Typo.h6" Class="analysis-card-title">카테고리별 지출</MudText>
                    </div>

                    @{
                        var total = _data.CategoryBreakdown.Sum(c => c.MonthlyAmountKRW);
                        var segments = BuildDonutSegments(_data.CategoryBreakdown, total);
                    }

                    <div class="donut-chart-wrap">
                        <svg viewBox="0 0 220 220" class="donut-chart">
                            <circle cx="110" cy="110" r="80" fill="none"
                                    stroke="rgba(255,255,255,0.04)" stroke-width="36" />
                            @foreach (var (seg, i) in segments.Select((s, i) => (s, i)))
                            {
                                var segmentColor = CategoryService.GetColor(_data.CategoryBreakdown[i].Category);
                                <circle cx="110" cy="110" r="80"
                                        fill="none"
                                        stroke="@segmentColor"
                                        stroke-width="36"
                                        stroke-dasharray="@seg.Dash @seg.Gap"
                                        stroke-dashoffset="@seg.Offset"
                                        style="transform-origin:110px 110px; opacity:0.9; cursor:pointer;"
                                        class="donut-seg" />
                            }
                            @((MarkupString)$"""
                                <text x="110" y="99" text-anchor="middle"
                                      style="fill:var(--text-secondary);font-size:10px;font-weight:600;font-family:Pretendard;">월 합계</text>
                                <text x="110" y="120" text-anchor="middle"
                                      style="fill:var(--gold-400);font-size:17px;font-weight:800;font-family:Pretendard;">₩{FormatCompact(total)}</text>
                                <text x="110" y="137" text-anchor="middle"
                                      style="fill:var(--text-secondary);font-size:9px;font-family:Pretendard;">{_data.CategoryBreakdown.Count}개 카테고리</text>
                            """)
                        </svg>
                    </div>

                    @foreach (var (cat, i) in _data.CategoryBreakdown.Select((c, i) => (c, i)))
                    {
                        var pct = total > 0 ? (cat.MonthlyAmountKRW / total * 100) : 0;
                        var catColor = CategoryService.GetColor(cat.Category);
                        <div class="category-breakdown-row">
                            <div class="category-color-dot" style="background:@catColor;"></div>
                            <MudText Typo="Typo.body2" Class="category-name">
                                @cat.Category
                            </MudText>
                            <MudText Typo="Typo.caption" Class="category-count">
                                @(cat.Count)개
                            </MudText>
                            <MudText Typo="Typo.body2" Class="category-amount">
                                ₩@cat.MonthlyAmountKRW.ToString("N0")
                            </MudText>
                            <div class="category-share">
                                <div class="category-share-track">
                                    <div class="category-share-fill"
                                         style="width:@((double)pct)%;background:@catColor;"></div>
                                </div>
                                <div class="category-share-text">
                                    @pct.ToString("F1")%
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </MudItem>

            <!-- Monthly Trend Chart -->
            <MudItem xs="12" lg="7" Class="fade-in-up fade-in-up-3">
                <div class="glass-card pa-5 spending-chart-card">
                    <div class="d-flex align-center mb-4 analysis-card-header">
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="color:var(--gold-400);" Class="mr-2" />
                        <MudText Typo="Typo.h6" Class="analysis-card-title">월별 지출 추이</MudText>
                    </div>

                    <div class="trend-chart-frame">
                        @((MarkupString)BuildTrendChartSvg(_data.MonthlyTrends, _selectedMonths))
                    </div>

                    @{
                        var visibleTrends = _data.MonthlyTrends.TakeLast(_selectedMonths).ToList();
                    }
                    @if (visibleTrends.Count > 0)
                    {
                        var highest = visibleTrends.OrderByDescending(t => t.TotalKRW).First();
                        var lowest = visibleTrends.Where(t => t.TotalKRW > 0).OrderBy(t => t.TotalKRW).FirstOrDefault();
                        <div class="trend-summary mt-3 pt-3">
                            <div class="trend-summary-item">
                                <div class="trend-summary-label">최고</div>
                                <div class="trend-summary-value" style="color:var(--accent-red);">₩@highest.TotalKRW.ToString("N0")</div>
                                <div class="trend-summary-date">@highest.Label</div>
                            </div>
                            @if (lowest != null)
                            {
                                <div class="trend-summary-item">
                                    <div class="trend-summary-label">최저</div>
                                    <div class="trend-summary-value" style="color:var(--accent-green);">₩@lowest.TotalKRW.ToString("N0")</div>
                                    <div class="trend-summary-date">@lowest.Label</div>
                                </div>
                            }
                            <div class="trend-summary-item">
                                <div class="trend-summary-label">평균</div>
                                <div class="trend-summary-value" style="color:var(--gold-400);">₩@((visibleTrends.Average(t => (double)t.TotalKRW)).ToString("N0"))</div>
                                <div class="trend-summary-date">@(_selectedMonths)개월</div>
                            </div>
                        </div>
                    }
                </div>
            </MudItem>
        </MudGrid>

        <!-- Category Detail Table -->
        <div class="glass-card pa-5 fade-in-up fade-in-up-4">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.TableChart" Style="color:var(--gold-400);" Class="mr-2" />
                <MudText Typo="Typo.h6" Style="font-weight:700;color:var(--text-primary);">카테고리 상세</MudText>
                <MudSpacer />
                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                         Style="background:rgba(99,102,241,0.1);color:var(--gold-400);font-size:0.72rem;">
                    @(_data.CategoryBreakdown.Count)개 카테고리
                </MudChip>
            </div>

            @{
                var catTotal = _data.CategoryBreakdown.Sum(c => c.MonthlyAmountKRW);
            }

            <MudTable Items="@_data.CategoryBreakdown" Hover="true" Dense="false"
                      Style="background:transparent;" Elevation="0">
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel SortBy='new Func<CategorySpend, object>(x => x.Category)'>
                            카테고리
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>구독 수</MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy='new Func<CategorySpend, object>(x => x.MonthlyAmountKRW)'
                                          InitialDirection="SortDirection.Descending">
                            월 지출
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>연간 지출</MudTh>
                    <MudTh>비중</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var rowColor = CategoryService.GetColor(context.Category);
                        var rowPct = catTotal > 0 ? (double)(context.MonthlyAmountKRW / catTotal * 100) : 0;
                    }
                    <MudTd>
                        <div class="d-flex align-center gap-2">
                            <div style="width:10px;height:10px;border-radius:3px;
                                        background:@rowColor;flex-shrink:0;"></div>
                            <span style="font-weight:600;color:var(--text-primary);">@context.Category</span>
                        </div>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                 Style="background:rgba(255,255,255,0.06);color:var(--text-secondary);font-size:0.75rem;">
                            @(context.Count)개
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <span style="font-weight:700;color:var(--gold-400);">
                            ₩@context.MonthlyAmountKRW.ToString("N0")
                        </span>
                    </MudTd>
                    <MudTd>
                        <span style="color:var(--text-secondary);">
                            ₩@((context.MonthlyAmountKRW * 12).ToString("N0"))
                        </span>
                    </MudTd>
                    <MudTd>
                        <div class="category-table-share">
                            <span class="category-table-share-value" style="color:@rowColor;">
                                @rowPct.ToString("F1")%
                            </span>
                            <div class="category-table-share-track">
                                <div class="category-table-share-fill"
                                     style="width:@rowPct%;background:@rowColor;"></div>
                            </div>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    }
</div>

<style>
    .spending-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .spending-page-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .period-control {
        display: flex;
        align-items: center;
        gap: 2px;
        padding: 3px;
        background: var(--surface-elevated);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        overflow: hidden;
    }

    .period-option {
        min-height: 32px;
        padding: 0 12px;
        border: 0;
        border-radius: 9px;
        background: transparent;
        color: var(--text-secondary);
        cursor: pointer;
        font-size: 0.78rem;
        font-weight: 700;
        line-height: 1;
        transition: background-color 0.18s ease, color 0.18s ease;
    }

    .period-option:hover {
        background: rgba(99,102,241,0.08);
        color: var(--text-primary);
    }

    .period-option.active {
        background: rgba(99,102,241,0.16);
        color: var(--gold-400);
    }

    .custom-period-entry {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        min-height: 32px;
        margin-left: 2px;
        padding: 0 10px 0 8px;
        border-left: 1px solid var(--border-subtle);
        border-radius: 8px;
        color: var(--text-secondary);
        font-size: 0.78rem;
        font-weight: 700;
    }

    .custom-period-entry.active {
        background: rgba(99,102,241,0.16);
        color: var(--gold-400);
    }

    .custom-period-label {
        color: inherit;
        opacity: 0.86;
    }

    .custom-period-input {
