@page "/subscriptions"
@attribute [Authorize]
@inject ISubscriptionApiService ApiService
@inject ICategoryService CategoryService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<PageTitle>구독 관리 — SubTrack</PageTitle>

<div class="fade-in-up">
    <div class="d-flex align-center justify-space-between mb-5">
        <div>
            <div class="page-title">구독 관리</div>
            <div class="page-subtitle">등록된 구독 서비스를 관리하세요</div>
        </div>
        <div class="d-flex gap-2 align-center" style="position: relative;">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ToggleExportPopover"
                       Style="border-radius:12px; font-weight:700; padding:8px 16px; background: rgba(99,102,241,0.05); border-color: rgba(99,102,241,0.3);">
                CSV 내보내기
            </MudButton>

            <MudPopover Open="@_isExportOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="pa-4 glass-popover-menu" Style="width: 280px; z-index: 9999;">
                <MudText Typo="Typo.subtitle2" Class="mb-2">파일 이름 입력</MudText>
                <MudTextField @bind-Value="_exportFileName" Label="파일명" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />
                <div class="d-flex justify-end gap-2">
                    <MudButton OnClick="ToggleExportPopover" Size="Size.Small">취소</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="ConfirmExport">다운로드</MudButton>
                </div>
            </MudPopover>

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddDialog"
                       Style="border-radius:12px; font-weight:700; padding:10px 20px;">
                구독 추가
            </MudButton>
        </div>
    </div>

    <div class="glass-card pa-4 mb-4 fade-in-up fade-in-up-1">
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_searchQuery"
                              Placeholder="서비스명 또는 카테고리로 검색..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              AdornmentColor="Color.Primary"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              OnKeyUp="FilterChanged" />
            </MudItem>
            <MudItem xs="6" sm="2">
                <MudSelect T="string" @bind-Value="_filterCategory" Label="카테고리"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           SelectedValuesChanged="FilterChanged">
                    <MudSelectItem Value="@("전체")">전체</MudSelectItem>
                    @foreach (var category in CategoryService.Categories)
                    {
                        <MudSelectItem Value="@category">@category</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="2">
                <MudSelect T="string" @bind-Value="_filterCurrency" Label="통화"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           SelectedValuesChanged="FilterChanged">
                    <MudSelectItem Value="@("전체")">전체</MudSelectItem>
                    <MudSelectItem Value="@("KRW")">KRW</MudSelectItem>
                    <MudSelectItem Value="@("USD")">USD</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="2">
                <MudSelect T="string" @bind-Value="_filterCycle" Label="결제 주기"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           SelectedValuesChanged="FilterChanged">
                    <MudSelectItem Value="@("전체")">전체</MudSelectItem>
                    <MudSelectItem Value="@("MONTHLY")">월간</MudSelectItem>
                    <MudSelectItem Value="@("YEARLY")">연간</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </div>

    <div class="subscription-summary-bar d-flex align-center justify-space-between mb-4 fade-in-up fade-in-up-2">
        <div class="subscription-summary-metrics d-flex align-center">
            <MudChip T="string" Icon="@Icons.Material.Filled.FilterList" 
                     Style="background: rgba(99,102,241,0.1); color: var(--accent-blue); font-weight: 700; font-size: 0.8rem; border-radius: 8px;">
                @FilteredSubscriptions.Count()개 서비스
            </MudChip>
            <MudChip T="string" Icon="@Icons.Material.Filled.Payments" 
                     Style="background: rgba(99,102,241,0.1); color: var(--accent-blue); font-weight: 700; font-size: 0.8rem; border-radius: 8px;">
                월 ₩@FilteredSubscriptions.Sum(s => s.MonthlyAmountInKRW).ToString("N0")
            </MudChip>
        </div>
        <div class="view-mode-toggle" role="group" aria-label="구독 보기 방식">
            <MudTooltip Text="리스트형 보기">
                <MudIconButton Icon="@Icons.Material.Filled.ViewList"
                               Size="Size.Small"
                               Class='@GetViewModeButtonClass(ListViewMode)'
                               aria-label="리스트형 보기"
                               OnClick='@(() => SetViewModeAsync(ListViewMode))' />
            </MudTooltip>
            <MudTooltip Text="카드형 보기">
                <MudIconButton Icon="@Icons.Material.Filled.GridView"
                               Size="Size.Small"
                               Class='@GetViewModeButtonClass(CardViewMode)'
                               aria-label="카드형 보기"
                               OnClick='@(() => SetViewModeAsync(CardViewMode))' />
            </MudTooltip>
        </div>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center pa-16">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else if (!FilteredSubscriptions.Any())
    {
        <div class="glass-card d-flex flex-column align-center justify-center pa-16 fade-in-up fade-in-up-3">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 4rem; color: var(--text-secondary); opacity:0.5;" Class="mb-4" />
            <MudText Typo="Typo.h6" Style="color: var(--text-secondary);">검색 결과가 없습니다.</MudText>
            <MudButton Color="Color.Primary" Variant="Variant.Text" OnClick="ResetFilters" Class="mt-2">필터 초기화</MudButton>
        </div>
    }
    else
    {
        @if (_viewMode == "list")
        {
            <div class="glass-card fade-in-up fade-in-up-3" style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; min-width: 1040px;">
                    <thead>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.08); color: var(--text-secondary); font-size: 0.85rem;">
                            <th style="padding: 16px 24px; text-align: left; font-weight: 500;">서비스</th>
                            <th style="padding: 16px 8px; text-align: center; font-weight: 500;">카테고리</th>
                            <th style="padding: 16px 8px; text-align: left; font-weight: 500;">결제 금액</th>
                            <th style="padding: 16px 8px; text-align: left; font-weight: 500;">원화 환산</th>
                            <th style="padding: 16px 8px; text-align: center; font-weight: 500;">주기</th>
                            <th style="padding: 16px 8px; text-align: center; font-weight: 500;">시작일</th>
                            <th style="padding: 16px 8px; text-align: center; font-weight: 500;">다음 결제일</th>
                            <th style="padding: 16px 8px; text-align: center; font-weight: 500;">D-DAY</th>
                            <th style="padding: 16px 8px; text-align: center; font-weight: 500;">상태</th>
                            <th style="padding: 16px 24px; text-align: right; font-weight: 500;">관리</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sub in FilteredSubscriptions)
                        {
                            <tr class="table-row-hover" style="border-bottom: 1px solid rgba(255,255,255,0.04); transition: background-color 0.2s;">
                                <td style="padding: 16px 24px;">
                                    <div class="d-flex align-center">
                                        <div style="background: rgba(255,255,255,0.05); border-radius: 10px; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-right: 16px;">
                                            @(sub.IconEmoji ?? "📦")
                                        </div>
                                        <div style="font-weight: 700; color: var(--text-primary); font-size: 0.95rem;">@sub.Name</div>
                                    </div>
                                </td>
                                <td style="padding: 16px 8px; text-align: center;">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="@GetCategoryChipStyle(sub.Category)">@sub.Category</MudChip>
                                </td>
                                <td style="padding: 16px 8px; text-align: left;">
                                    <div style="font-weight: 800; color: var(--text-primary); font-size: 0.95rem;">@(sub.Currency == "KRW" ? "₩" : "$")@sub.Amount.ToString("N2")</div>
                                    <div style="font-size: 0.75rem; color: var(--text-secondary);">@sub.Currency</div>
                                </td>
                                <td style="padding: 16px 8px; text-align: left;">
                                    <div style="font-weight: 800; color: var(--accent-blue); font-size: 0.95rem;">₩@sub.AmountInKRW.ToString("N0")</div>
                                </td>
                                <td style="padding: 16px 8px; text-align: center;">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="color: #52c41a; border-color: rgba(82,196,26,0.5); background: rgba(82,196,26,0.05);">@(sub.BillingCycle == "MONTHLY" ? "월간" : "연간")</MudChip>
                                </td>
                                <td style="padding: 16px 8px; text-align: center; color: var(--text-secondary); font-weight: 500; font-size: 0.86rem;">@sub.StartDate.ToString("yyyy.MM.dd")</td>
                                <td style="padding: 16px 8px; text-align: center; color: var(--text-primary); font-weight: 500; font-size: 0.9rem;">@sub.NextBillingDate.ToString("yyyy.MM.dd")</td>
                                <td style="padding: 16px 8px; text-align: center;">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="@GetDDayChipStyle(sub.DaysUntilBilling)">@sub.DaysLabel</MudChip>
                                </td>
                                <td style="padding: 16px 8px; text-align: center;">
                                    <MudSwitch T="bool" Value="@sub.IsActive" ValueChanged="@((value) => ToggleStatus(sub, value))" Color="Color.Primary" Class="custom-purple-toggle mx-auto" Style="margin-left: 12px;" />
                                </td>
                                <td style="padding: 16px 24px; text-align: right;">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenEditDialog(sub))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteSubscription(sub))" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <MudGrid Spacing="3" Class="fade-in-up fade-in-up-3">
                @foreach (var sub in FilteredSubscriptions)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <div class="glass-card pa-4 d-flex flex-column" style="height: 100%; position: relative;">
                            
                            <div class="d-flex align-center mb-3">
                                <div style="background: rgba(255,255,255,0.05); border-radius: 10px; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-right: 12px;">
                                    @(sub.IconEmoji ?? "📦")
                                </div>
                                <div style="flex-grow: 1; overflow: hidden;">
                                    <div style="font-weight: 700; color: var(--text-primary); font-size: 1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@sub.Name</div>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="@(GetCategoryChipStyle(sub.Category) + "margin: 4px 0 0 0; padding: 0 6px; font-size: 0.7rem;")">@sub.Category</MudChip>
                                </div>
                                <div>
                                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Color="Color.Secondary">
                                        <MudMenuItem OnClick="@(() => OpenEditDialog(sub))">수정</MudMenuItem>
                                        <MudMenuItem OnClick="@(() => DeleteSubscription(sub))"><span style="color:var(--accent-red);">삭제</span></MudMenuItem>
                                    </MudMenu>
                                </div>
                            </div>
                            
                            <div class="subscription-card-divider"></div>

                            <div class="mb-4">
                                <div style="font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 4px;">결제 금액 (@(sub.BillingCycle == "MONTHLY" ? "월간" : "연간"))</div>
                                <div style="font-weight: 800; color: var(--accent-blue); font-size: 1.4rem;">
                                    ₩@sub.AmountInKRW.ToString("N0")
                                </div>
                                @if(sub.Currency != "KRW") {
                                    <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 2px;">(@(sub.Currency == "USD" ? "$" : sub.Currency)@sub.Amount.ToString("N2"))</div>
                                }
                            </div>

                            <div class="mt-auto d-flex align-center justify-space-between" style="background: rgba(0,0,0,0.2); padding: 8px 12px; border-radius: 10px;">
                                <div class="d-flex align-center">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="@GetDDayChipStyle(sub.DaysUntilBilling)">@sub.DaysLabel</MudChip>
                                    <span style="font-size: 0.8rem; font-weight: 500; color: var(--text-secondary); margin-left: 8px;">@sub.NextBillingDate.ToString("MM.dd")</span>
                                </div>
                                <MudSwitch T="bool" Value="@sub.IsActive" ValueChanged="@((value) => ToggleStatus(sub, value))" Color="Color.Primary" Class="custom-purple-toggle" Style="margin: 0;" />
                            </div>
                            
                        </div>
                    </MudItem>
                }
            </MudGrid>
        }
    }
</div>

<style>
    .subscription-summary-bar { gap: 12px; flex-wrap: wrap; }
    .subscription-summary-metrics { gap: 12px; flex-wrap: wrap; }
    .view-mode-toggle { display: flex; align-items: center; gap: 2px; padding: 3px; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; background: rgba(255,255,255,0.03); }
    .view-mode-button { width: 36px; height: 36px; border-radius: 8px !important; color: var(--text-secondary) !important; }
    .view-mode-button.view-mode-button-active { color: var(--accent-blue) !important; background: rgba(99,102,241,0.14) !important; }
    .subscription-card-divider { flex: 0 0 1px; height: 1px; background-color: rgba(255,255,255,0.08); margin: 8px 0 16px; }
    .custom-purple-toggle .mud-switch-track { background-color: rgba(107,114,128,0.55) !important; }
    .custom-purple-toggle.mud-checked .mud-switch-track { background-color: var(--gold-500) !important; }
    .table-row-hover:hover { background-color: rgba(255,255,255,0.03); }
    .glass-popover-menu { background: rgba(15, 23, 42, 0.95) !important; backdrop-filter: blur(20px) !important; border-radius: 12px !important; border: 1px solid rgba(255,255,255,0.1) !important; box-shadow: 0 8px 32px rgba(0,0,0,0.6) !important; }
</style>

@code {
    private List<SubscriptionDto> _subscriptions = new();
    private bool _loading = true;
    private bool _isExportOpen = false;
    private string _exportFileName = "나의_구독목록";
    private string _searchQuery = "";
    private string _filterCategory = "전체";
    private string _filterCurrency = "전체";
    private string _filterCycle = "전체";
    
    private const string KeyViewMode = "subtrack_view_mode";
    private const string ListViewMode = "list";
    private const string CardViewMode = "card";

    // 화면 표시 방식 저장 변수
    private string _viewMode = ListViewMode; 

    private IEnumerable<SubscriptionDto> FilteredSubscriptions => _subscriptions.Where(s =>
        (string.IsNullOrWhiteSpace(_searchQuery) || 
         s.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || 
         s.Category.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)) &&
        (_filterCategory == "전체" || s.Category == _filterCategory) &&
        (_filterCurrency == "전체" || s.Currency == _filterCurrency) &&
        (_filterCycle == "전체" || s.BillingCycle == _filterCycle)
    ).OrderBy(s => s.DaysUntilBilling);

    private void ToggleExportPopover() => _isExportOpen = !_isExportOpen;

    private async Task ConfirmExport()
    {
        _isExportOpen = false;
        await ExportToCsv();
    }

    private async Task ExportToCsv()
    {
        var fileName = _exportFileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase) ? _exportFileName : $"{_exportFileName}.csv";
        var sb = new System.Text.StringBuilder();
        sb.Append('\uFEFF');
        sb.AppendLine("서비스 이름,카테고리,원화 환산 금액,결제 주기,구독 시작일,다음 결제일");

        foreach (var sub in FilteredSubscriptions)
        {
            sb.AppendLine($"\"{sub.Name}\",\"{sub.Category}\",{sub.AmountInKRW},{(sub.BillingCycle == "MONTHLY" ? "월간" : "연간")},{sub.StartDate:yyyy.MM.dd},{sub.NextBillingDate:yyyy.MM.dd}");
        }

        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(sb.ToString()));
        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv;charset=utf-8;", base64);

        Snackbar.Add($"'{fileName}' 다운로드 시작!", Severity.Success);
    }


    protected override async Task OnInitializedAsync()
    {
        var storedViewMode = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", KeyViewMode);
        _viewMode = IsValidViewMode(storedViewMode) ? storedViewMode! : ListViewMode;
        await LoadData();
    }

    private async Task SetViewModeAsync(string viewMode)
    {
        if (!IsValidViewMode(viewMode) || _viewMode == viewMode)
        {
            return;
        }

        var previousViewMode = _viewMode;
        _viewMode = viewMode;

        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", KeyViewMode, viewMode);
        }
        catch (Exception ex)
        {
            _viewMode = previousViewMode;
            Snackbar.Add($"보기 방식 저장 실패: {ex.Message}", Severity.Error);
        }
    }

    private string GetViewModeButtonClass(string viewMode) =>
        _viewMode == viewMode ? "view-mode-button view-mode-button-active" : "view-mode-button";

    private static bool IsValidViewMode(string? viewMode) => viewMode is ListViewMode or CardViewMode;

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _subscriptions = await ApiService.GetSubscriptionsAsync();
            await CategoryService.EnsureLoadedAsync(_subscriptions.Select(s => s.Category));
        }
        catch
        {
            _subscriptions = GetMockSubscriptions();
            await CategoryService.EnsureLoadedAsync();
        }
        finally { _loading = false; }
    }

    private void FilterChanged(IEnumerable<string> _) => StateHasChanged();
    private void FilterChanged(KeyboardEventArgs _) => StateHasChanged();
    
    private void ResetFilters() { _searchQuery = ""; _filterCategory = "전체"; _filterCurrency = "전체"; _filterCycle = "전체"; StateHasChanged(); }

    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, BackdropClick = false };
        var dialog = await DialogService.ShowAsync<AddEditSubscriptionDialog>("새 구독 추가", options);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled) await LoadData();
    }

    private async Task OpenEditDialog(SubscriptionDto sub)
    {
        var parameters = new DialogParameters { ["Subscription"] = sub };
        var options = new DialogOptions { CloseOnEscapeKey = true, BackdropClick = false };
        var dialog = await DialogService.ShowAsync<AddEditSubscriptionDialog>("구독 수정", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled) await LoadData();
    }
    
    private async Task ToggleStatus(SubscriptionDto sub, bool isActive)
    {
        var original = sub.IsActive;
        sub.IsActive = isActive;

        try
        {
            var result = await ApiService.UpdateAsync(sub.Id, ToUpdateRequest(sub));
            if (result == null)
            {
                sub.IsActive = original;
                Snackbar.Add("구독을 찾을 수 없습니다.", Severity.Error);
                return;
            }

            Snackbar.Add(isActive ? $"{sub.Name} 활성화 됨" : $"{sub.Name} 해지 처리됨", isActive ? Severity.Success : Severity.Warning);
            await LoadData();
        }
        catch
        {
            sub.IsActive = original;
            Snackbar.Add("상태 변경에 실패했습니다. 다시 시도해주세요.", Severity.Error);
        }
    }
    
    private async Task DeleteSubscription(SubscriptionDto sub)
    {
        try
        {
            await ApiService.DeleteAsync(sub.Id);
            Snackbar.Add($"{sub.Name} 삭제됨", Severity.Success);
            await LoadData();
        }
        catch
        {
            Snackbar.Add("삭제에 실패했습니다. 다시 시도해주세요.", Severity.Error);
        }
    }

    private static UpdateSubscriptionRequest ToUpdateRequest(SubscriptionDto sub) => new()
    {
        Name = sub.Name,
        Category = sub.Category,
        Amount = sub.Amount,
        Currency = sub.Currency,
        BillingCycle = sub.BillingCycle,
        StartDate = sub.StartDate,
        NextBillingDate = sub.NextBillingDate,
        IconEmoji = sub.IconEmoji,
        Notes = sub.Notes,
        IsActive = sub.IsActive
    };
    
    private string GetCategoryChipStyle(string category) => category switch { "엔터테인먼트" => "color: #ff4d4f; border-color: rgba(255,77,79,0.5); background: rgba(255,77,79,0.05);", "창작 도구" => "color: #ff75c3; border-color: rgba(255,117,195,0.5); background: rgba(255,117,195,0.05);", "음악" => "color: #b37feb; border-color: rgba(179,127,235,0.5); background: rgba(179,127,235,0.05);", "개발 도구" => "color: #69c0ff; border-color: rgba(105,192,255,0.5); background: rgba(105,192,255,0.05);", _ => "color: var(--text-secondary); border-color: rgba(255,255,255,0.2);" };
    
    private string GetDDayChipStyle(int days) => days <= 3 ? "color: #ff4d4f; border-color: rgba(255,77,79,0.5); background: rgba(255,77,79,0.05);" : days <= 7 ? "color: #faad14; border-color: rgba(250,173,20,0.5); background: rgba(250,173,20,0.05);" : "color: #52c41a; border-color: rgba(82,196,26,0.5); background: rgba(82,196,26,0.05);";
    
